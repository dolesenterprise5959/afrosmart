# AfroSmart environment template.
# Copy this file to `.env.local` and fill in values from your Firebase project.
# `.env.local` is gitignored — never commit real credentials.

# --- Firebase Web SDK (client) — safe to expose to the browser ---
# Firebase Console → Project settings → General → "Your apps" (Web app config)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# NOTE: NEXT_PUBLIC_* vars are needed at BUILD time (they're inlined into the
# client bundle) AND at runtime. The FIREBASE_* server vars below are runtime-only.

# --- Firebase Admin SDK (server only) — KEEP SECRET ---
# Used for LOCAL development and the seed script.
# In PRODUCTION on Google Cloud (Firebase App Hosting / Cloud Run), leave these
# UNSET and rely on Application Default Credentials — no private key is shipped.
# See lib/firebase/admin.ts and docs/LAUNCH_RUNBOOK.md §7.
# Firebase Console → Project settings → Service accounts → "Generate new private key"
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key on one line with literal \n for newlines, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=
